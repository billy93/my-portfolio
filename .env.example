# Database (Neon PostgreSQL - get your connection string from https://console.neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/portfolio?sslmode=require"

# NextAuth v5 (AUTH_SECRET is required — run: openssl rand -base64 32)
AUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# API Key for external access (OpenCode tools, etc.)
PORTFOLIO_API_KEY="generate-a-random-api-key-here"

# UploadThing (get from https://uploadthing.com)
UPLOADTHING_TOKEN=""
